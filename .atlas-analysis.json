  "publicApiSurface": [
    "AuthController::login() - User authentication",
    "AdminController::revisar() - Review and approve/reject returns",
    "PanelController::registrar() - Register new product returns",
    "ConsultaController::index() - Query return history",
    "DevolucionModel::guardar() - Save return record",
    "DevolucionModel::obtenerPendientes() - Get pending returns",
    "DevolucionModel::procesarRevision() - Process admin review",
    "DevolucionModel::obtenerEstadisticas() - Get dashboard statistics"
